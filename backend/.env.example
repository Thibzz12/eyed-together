# ============================================================
#  Modèle de configuration — À COPIER vers un fichier `.env`
#  (le vrai `.env` ne doit JAMAIS être commité : voir .gitignore)
# ============================================================

# --- Application ---
APP_NAME="Coworking Booking"
ENVIRONMENT="development"          # development | production
DEBUG=true

# --- Sécurité ---
# ⚠️ En prod : générer une vraie clé aléatoire (ex: `python -c "import secrets;print(secrets.token_hex(32))"`)
#    et la stocker dans Azure Key Vault, jamais en clair ici.
SECRET_KEY="dev-insecure-change-me"

# --- Base de données ---
# Dev  : SQLite (aucun serveur à installer)
DATABASE_URL="sqlite:///./coworking.db"
# Prod : PostgreSQL (décommenter et remplir)
# DATABASE_URL="postgresql+psycopg2://user:password@host:5432/coworking"

# --- Microsoft Entra ID (SSO) — à remplir à l'étape Auth ---
ENTRA_TENANT_ID=""
ENTRA_CLIENT_ID=""
ENTRA_CLIENT_SECRET=""
ENTRA_REDIRECT_URI="http://localhost:8000/auth/callback"

# --- CORS (origine autorisée du frontend) ---
FRONTEND_ORIGIN="http://localhost:5173"

# --- Intranet WordPress ---
WORDPRESS_URL="https://weared.team"
# Secret partagé avec l'endpoint d'auth WordPress (doit être IDENTIQUE à EYED_APP_SECRET
# dans le fichier PHP posé sur WordPress). Génère-le avec :
#   python -c "import secrets; print(secrets.token_hex(32))"
# Laisse vide pour rester en mode démo (connexion WordPress désactivée).
WP_APP_SECRET=""

# --- Administrateurs de l'application (liste blanche, PAS le rôle WordPress) ---
# Emails séparés par des virgules. Seules ces personnes voient l'onglet Administration.
ADMIN_EMAILS="t.pirard@eyedpharma.com,o.vanbrabant@eyedpharma.com"
